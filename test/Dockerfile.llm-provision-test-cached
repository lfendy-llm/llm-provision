# Test container for provisioning a fresh Ubuntu Server
# Based on the llm-provision-test base image with pre-cached init.sh
# dependencies (apt update/upgrade, git, make, ansible) so tests run faster.

FROM llm-provision-test

# ---- Pre-cached dependencies (via install-deps.sh) ----
# Kept in sync with install-deps.sh — any change there triggers a rebuild.
COPY install-deps.sh /tmp/install-deps.sh
RUN bash /tmp/install-deps.sh && rm /tmp/install-deps.sh

# Set working directory to the user's home
WORKDIR /home/localuser
